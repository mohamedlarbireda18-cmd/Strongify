generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                  String            @id @default(cuid())
  email               String            @unique
  name                String?
  password            String?
  googleId            String?           @unique
  avatar              String?
  status              String            @default("PENDING")
  verificationCode    String?
  verificationExpires DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  workouts            Workout[]
  programs            Program[]
  exerciseRecords     ExerciseRecord[]
  weightLogs          WeightLog[]
  customExercises     CustomExercise[]
  workoutSessions     WorkoutSession[]
}

model Exercise {
  id                   String                   @id @default(cuid())
  name                 String
  muscleGroup          String
  type                 String
  description          String?
  videoUrl             String?
  imageUrl             String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  programItems         ProgramItem[]
  workoutExercises     WorkoutExercise[]
  sessionExercises     WorkoutSessionExercise[]
  records              ExerciseRecord[]
}

model Program {
  id          String        @id @default(cuid())
  name        String
  description String?
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       ProgramItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ProgramItem {
  id         String   @id @default(cuid())
  programId  String
  program    Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  order      Int
  sets       Int?
  reps       Int?
  weight     Float?
  restTime   Int?
  notes      String?
}

model Workout {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId   String?
  date        DateTime          @default(now())
  duration    Int?
  notes       String?
  totalVolume Float?
  createdAt   DateTime          @default(now())
  exercises   WorkoutExercise[]
  sessions    WorkoutSession[]
  name        String            @default("Untitled Workout")  
  type        String            @default("CUSTOM")             
}

model WorkoutExercise {
  id         String        @id @default(cuid())
  workoutId  String
  workout    Workout       @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise      @relation(fields: [exerciseId], references: [id])
  order      Int
  notes      String?
  sets       ExerciseSet[]
}

model ExerciseSet {
  id                String          @id @default(cuid())
  workoutExerciseId String
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  setNumber         Int
  weight            Float
  reps              Int
  isDropSet         Boolean         @default(false)
  isMicroReps       Boolean         @default(false)
  rpe               Int?
  notes             String?
}

model ExerciseRecord {
  id          String   @id @default(cuid())
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime @default(now())
  maxWeight  Float
  maxReps    Int
  totalVolume Float
  createdAt  DateTime @default(now())
}

model WeightLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weight    Float
  date      DateTime @default(now())
}

model CustomExercise {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  muscleGroup String
  type        String   @default("BILATERAL")
  imageUrl    String?
  createdAt   DateTime @default(now())
}

model WorkoutSession {
  id          String                    @id @default(cuid())
  workoutId   String
  workout     Workout                   @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  userId      String
  user        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime                  @default(now())
  duration    Int?
  notes       String?
  totalVolume Float?
  createdAt   DateTime                  @default(now())
  exercises   WorkoutSessionExercise[]
}

model WorkoutSessionExercise {
  id          String              @id @default(cuid())
  sessionId   String
  session     WorkoutSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId  String
  exercise    Exercise            @relation(fields: [exerciseId], references: [id])
  order       Int
  notes       String?
  sets        SessionSet[]
}

model SessionSet {
  id                      String                  @id @default(cuid())
  sessionExerciseId       String
  sessionExercise         WorkoutSessionExercise  @relation(fields: [sessionExerciseId], references: [id], onDelete: Cascade)
  setNumber               Int
  weight                  Float
  reps                    Int
  isDropSet               Boolean                 @default(false)
  isMicroReps             Boolean                 @default(false)
  rpe                     Int?
  notes                   String?
}